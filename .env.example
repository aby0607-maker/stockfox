# CMOTS API (primary data source — BSE fundamentals, price data, shareholding)
CMOTS_API_TOKEN=

# DhanHQ API (price data fallback — historical OHLCV when CMOTS is empty)
DHAN_ACCESS_TOKEN=

# IndianAPI.in (fundamentals fallback — 12-year annual data depth)
INDIANAPI_KEY=

# Screener.in (qual data — annual report parsed data for ~18 qual signals)
# Optional: session ID for authenticated access (higher rate limits)
SCREENER_SESSION_ID=

# Finnhub (analyst consensus — free tier, 60 req/min)
# Get a free key at https://finnhub.io/register
FINNHUB_API_KEY=
