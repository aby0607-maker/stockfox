{
  "rewrites": [
    {
      "source": "/api/cmots/(.*)",
      "destination": "/api/cmots/$1"
    },
    {
      "source": "/api/dhan/(.*)",
      "destination": "/api/dhan/$1"
    },
    {
      "source": "/api/indianapi/(.*)",
      "destination": "/api/indianapi/$1"
    },
    {
      "source": "/api/screener/(.*)",
      "destination": "/api/screener/$1"
    },
    {
      "source": "/api/bse/(.*)",
      "destination": "/api/bse/$1"
    },
    {
      "source": "/api/trendlyne/(.*)",
      "destination": "/api/trendlyne/$1"
    },
    {
      "source": "/api/finnhub/(.*)",
      "destination": "/api/finnhub/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
